# ─── ISTV SLACK BOT v2 — ENVIRONMENT VARIABLES ───────────────────────────────
# Copy this to .env for local dev. Set all in Vercel dashboard for production.

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Taulant and Tyler's Slack member IDs (click profile → ⋯ → Copy member ID)
TAULANT_SLACK_ID=PASTE_YOUR_SLACK_ID
TYLER_SLACK_ID=PASTE_TYLERS_SLACK_ID

# The #ai-onboarding-updates channel ID (right-click channel → Copy channel ID)
ADMIN_CHANNEL_ID=PASTE_CHANNEL_ID

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The long ID from your Google Sheet URL
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Paste the entire private key including BEGIN/END lines
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR KEY\n-----END PRIVATE KEY-----\n"

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Monday.com ────────────────────────────────────────────────────────────────
# Get API key from monday.com → Avatar → Admin → API
MONDAY_API_KEY=your-monday-api-key
# The board ID where new hire tasks live (visible in board URL)
MONDAY_BOARD_ID=your-board-id

# ── Zoom ──────────────────────────────────────────────────────────────────────
# Get from Zoom App Marketplace → Your App → Feature → Webhook
ZOOM_VERIFICATION_TOKEN=your-zoom-verification-token
# OAuth token for downloading transcripts
ZOOM_OAUTH_TOKEN=your-zoom-oauth-token

# ── App config ────────────────────────────────────────────────────────────────
# Public URL to the onboarding PDF (Google Drive public link)
ONBOARDING_PDF_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view
# URL of the onboarding intake form (your Vercel form app)
ONBOARDING_FORM_URL=https://your-form.vercel.app
# Secret for the Make.com webhook endpoint
WEBHOOK_SECRET=change-this-to-something-strong
# Secret for the Vercel cron endpoint
CRON_SECRET=change-this-too
# Enable cron jobs locally (set to true to test crons)
ENABLE_CRON=false
PORT=3000
NODE_ENV=development
