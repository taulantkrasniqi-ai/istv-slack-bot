{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  "crons": [
    { "path": "/cron/morning",        "schedule": "0 14 * * 1-5"  },
    { "path": "/cron/profile-check",  "schedule": "0 15 * * 1-5"  },
    { "path": "/cron/dloa-reminder",  "schedule": "30 21 * * 1-5" },
    { "path": "/cron/eod",            "schedule": "0 22 * * 1-5"  },
    { "path": "/cron/dloa-check",     "schedule": "0 23 * * 1-5"  },
    { "path": "/cron/weekly",         "schedule": "30 22 * * 5"   },
    { "path": "/cron/silence-check",  "schedule": "0 17 * * 1-5"  },
    { "path": "/cron/weekly-digest",  "schedule": "0 14 * * 1"    }
  ]
}
