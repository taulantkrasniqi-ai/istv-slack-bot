{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/cron/poll",
      "schedule": "*/5 * * * *"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "ENABLE_CRON": "true"
  }
}
